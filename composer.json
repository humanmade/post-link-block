{
	"name": "humanmade/post-link-block",
	"description": "A block that wraps inner blocks in a link to the current post, for use in query loops.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Human Made Limited",
			"email": "hello@humanmade.com"
		}
	],
	"require": {
		"php": ">=8.2"
	},
	"require-dev": {
		"humanmade/coding-standards": "dev-upgrade-wpcs"
	},
	"scripts": {
		"lint": [
			"phpcs --standard=phpcs.xml.dist"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
